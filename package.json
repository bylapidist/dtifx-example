{
  "name": "dtifx-example",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal production-ready DTIFx stack example",
  "engines": {
    "node": "^24.0.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --check",
    "format:write": "prettier . --write",
    "kernel:start": "design-lint kernel start --config-path designlint.config.js",
    "kernel:start:http": "design-lint kernel start --config-path designlint.config.js --http-port 7341",
    "kernel:start:no-http": "design-lint kernel start --config-path designlint.config.js --no-http",
    "kernel:stop": "design-lint kernel stop",
    "kernel:status": "design-lint kernel status",
    "design-lint": "design-lint \"src/**/*.{css,scss,less,js,jsx,ts,tsx}\" --config designlint.config.js",
    "design-lint:validate": "design-lint validate --config designlint.config.js",
    "design-lint:tokens": "design-lint tokens --config designlint.config.js --out ops/artifacts/build/design-tokens.json",
    "design-lint:snapshot": "design-lint export-runtime-snapshot --out ops/artifacts/build/kernel-snapshot.bin",
    "design-lint:docs": "design-lint docs --config designlint.config.js --out ops/artifacts/docs --site-format markdown",
    "design-lint:sarif": "mkdir -p ops/artifacts/lint && design-lint \"src/**/*.{css,scss,less,js,jsx,ts,tsx}\" --config designlint.config.js --format sarif --output ops/artifacts/lint/report.sarif",
    "design-lint:summary": "design-lint \"src/**/*.{css,scss,less,js,jsx,ts,tsx}\" --config designlint.config.js --format ./ops/formatters/summary.js",
    "design-lint:fix": "design-lint \"src/**/*.{css,scss,less,js,jsx,ts,tsx}\" --config designlint.config.js --fix",
    "design-lint:cache": "design-lint \"src/**/*.{css,scss,less,js,jsx,ts,tsx}\" --config designlint.config.js --cache",
    "design-lint:cache-location": "design-lint \"src/**/*.{css,scss,less,js,jsx,ts,tsx}\" --config designlint.config.js --cache --cache-location .designlintcache",
    "design-lint:check": "design-lint \"src/**/*.{css,scss,less,js,jsx,ts,tsx}\" --config designlint.config.js --fail-on-empty --max-warnings 100",
    "design-lint:api-check": "node ops/scripts/lint-check.js",
    "design-lint:generate-tokens": "node ops/scripts/generate-tokens.js",
    "design-lint:watch": "design-lint \"src/**/*.{css,scss,less,js,jsx,ts,tsx}\" --config designlint.config.js --watch --cache",
    "design-lint:report": "mkdir -p ops/artifacts/lint && design-lint \"src/**/*.{css,scss,less,js,jsx,ts,tsx}\" --config designlint.config.js --report ops/artifacts/lint/results.json",
    "design-lint:snapshot-diff": "design-lint export-runtime-snapshot --out ops/artifacts/snapshots/current.bin && design-lint diff ops/artifacts/snapshots/baseline.bin ops/artifacts/snapshots/current.bin --format json",
    "design-lint:dscp": "mkdir -p ops/artifacts/lint && design-lint export-design-system-md --out ops/artifacts/lint/DESIGN_LINT.md --lint --config designlint.config.js",
    "design-lint:quiet": "design-lint \"src/**/*.{css,scss,less,js,jsx,ts,tsx}\" --config designlint.config.js --quiet",
    "design-lint:tokens-themed": "design-lint tokens --config designlint.config.js --theme default --out ops/artifacts/build/design-tokens-default.json",
    "design-lint:ignore-path": "design-lint \"src/**/*.{css,scss,less,js,jsx,ts,tsx}\" --config designlint.config.js --ignore-path .gitignore",
    "kernel:token-add": "design-lint token add \"#/clr/new\" --name \"New colour\" --type color --value '{\"colorSpace\":\"srgb\",\"components\":[1,0,0]}'",
    "kernel:token-deprecate": "design-lint token deprecate \"#/clr/accent\" --replacement \"#/clr/brand\"",
    "kernel:component-register": "design-lint component register Button --package src/components --version 0.1.0 --replaces LegacyButton",
    "kernel:rule-configure": "design-lint rule configure design-token/colors --severity error --options '{\"allow\":[\"named\"]}'",
    "dtif:validate": "dtifx build validate --config build/dtif-validate.config.mjs",
    "dtif:build": "dtifx build generate --config build/dtif-build.config.mjs",
    "dtif:diff": "dtifx diff compare ops/artifacts/diff/baseline.dtif.json tokens/catalog.tokens.json --format json --output ops/artifacts/diff/report.json && node -e \"const fs=require('node:fs');const path=require('node:path');const report='ops/artifacts/diff/report.json';const from='file://'+process.cwd().split(path.sep).join('/');const to='file:///workspace/dtifx-example';fs.writeFileSync(report,fs.readFileSync(report,'utf8').replaceAll(from,to));\" && dtifx diff compare ops/artifacts/diff/baseline.dtif.json tokens/catalog.tokens.json",
    "dtif:dscp": "dtifx build generate --config build/dtif-dscp.config.mjs && dtifx dscp generate --from ops/artifacts/dscp/ --out DESIGN_SYSTEM.md",
    "dtif:audit": "dtifx audit run --config audit/dtif-audit.config.mjs --reporter json --reporter markdown --out-dir ops/artifacts/audit",
    "verify": "pnpm run lint && pnpm run design-lint"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@dtifx/audit": "5.1.0",
    "@dtifx/build": "5.1.0",
    "@dtifx/cli": "5.1.0",
    "@dtifx/diff": "5.1.0",
    "@eslint/js": "10.0.1",
    "@lapidist/design-lint": "^8.0.0",
    "@lapidist/design-lint-config-ai-agent": "^1.0.1",
    "@lapidist/design-lint-config-recommended": "^1.0.1",
    "@lapidist/design-lint-config-strict": "^1.0.1",
    "ajv": "^8.17.1",
    "eslint": "10.4.1",
    "prettier": "3.8.3",
    "zod": "^4.4.3"
  },
  "type": "module"
}
